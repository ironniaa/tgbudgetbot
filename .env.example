# Скопируйте этот файл в .env и заполните реальными значениями.

BOT_TOKEN=your_telegram_bot_token
FIRST_ID=123456789
SECOND_ID=987654321
GOOGLE_SHEET_ID=your_google_sheet_id

# Локально/на VPS с постоянной файловой системой достаточно положить
# credentials/google.json (service account ключ Google, см. README.md) —
# GOOGLE_CREDENTIALS_JSON ниже можно не задавать.
#
# На хостинге с эфемерной файловой системой (пересобирает контейнер при
# каждом деплое, файл credentials/google.json не переживает рестарт) —
# вместо файла задайте содержимое JSON-ключа целиком в этой переменной:
# GOOGLE_CREDENTIALS_JSON={"type": "service_account", ...}
